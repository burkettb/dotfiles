yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa



# Rules for application placement
# Space 2: Main Safari Window
yabai -m rule --add app="Safari" title="Main Safari Window Title" space=2

# Space 3: iTerm2
yabai -m rule --add app="iTerm2" space=3

# Space 4: Second Safari Window
yabai -m rule --add app="Safari" title="Second Safari Window Title" space=4

# Space 5: ChatGPT
yabai -m rule --add app="ChatGPT" space=5

# Space 6: Discord
yabai -m rule --add app="Discord" space=6

