# Seeded once by chezmoi (create_ source): applied only when ~/.codex/config.toml
# does not exist. After that, the Codex app owns the file and rewrites it freely
# (plugins, marketplaces, node_repl, trust state). To re-seed a machine, delete
# ~/.codex/config.toml and run `chezmoi apply`.

model = "gpt-5.6-sol"
personality = "pragmatic"
model_reasoning_effort = "high"
approval_policy = "on-request"
approvals_reviewer = "user"
default_permissions = "safe-workspace"
web_search = "cached"

[mcp_servers.chrome-devtools]
command = "npx"
args = ["chrome-devtools-mcp@latest"]
default_tools_approval_mode = "prompt"
enabled = false

[mcp_servers.context7]
url = "https://mcp.context7.com/mcp"
env_http_headers = { "CONTEXT7_API_KEY" = "CONTEXT7_API_KEY" }
default_tools_approval_mode = "auto"

[mcp_servers.playwright]
command = "npx"
args = ["@playwright/mcp@latest"]
default_tools_approval_mode = "prompt"
enabled = false

[mcp_servers.openaiDeveloperDocs]
url = "https://developers.openai.com/mcp"
default_tools_approval_mode = "auto"

[mcp_servers.github]
url = "https://api.githubcopilot.com/mcp/"
bearer_token_env_var = "GITHUB_TOKEN"
default_tools_approval_mode = "writes"
enabled = false

[apps._default]
approvals_reviewer = "user"
default_tools_approval_mode = "writes"
destructive_enabled = false
open_world_enabled = false

[shell_environment_policy]
exclude = ["*API_KEY*", "*PASSWORD*", "*SECRET*", "*TOKEN*", "AWS_*", "DATABASE_URL", "POSTGRES_URL", "REDIS_URL"]

[permissions.safe-workspace]
extends = ":workspace"
description = "Workspace access with secrets and credential stores denied"

[permissions.safe-workspace.filesystem]
glob_scan_max_depth = 20
"{{ .chezmoi.homeDir }}/.aws" = "deny"
"{{ .chezmoi.homeDir }}/.gnupg" = "deny"
"{{ .chezmoi.homeDir }}/.kube" = "deny"
"{{ .chezmoi.homeDir }}/.config/gcloud" = "deny"
"{{ .chezmoi.homeDir }}/.docker/config.json" = "deny"
"{{ .chezmoi.homeDir }}/Library/Keychains" = "deny"

[permissions.safe-workspace.filesystem.":workspace_roots"]
"**/.env" = "deny"
"**/.env.*" = "deny"
"**/secrets/**" = "deny"
"**/.secrets/**" = "deny"
"**/credentials/**" = "deny"
"**/.npmrc" = "deny"
"**/.pypirc" = "deny"
"**/.netrc" = "deny"
"**/.git-credentials" = "deny"
"**/*.pem" = "deny"
"**/*.key" = "deny"
"**/*.p12" = "deny"
"**/*.pfx" = "deny"

[features]
multi_agent = true
js_repl = false

[desktop]
preventSleepWhileRunning = true
keepRemoteControlAwakeWhilePluggedIn = true
followUpQueueMode = "queue"
dock-icon-preference = "codex-system"
