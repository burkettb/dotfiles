        "selector": "JSXOpeningElement[name.name='ActivityItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|actor|title|time|body|icon|avatar|tone|key|ref|className|style|children)$/]",
        "message": "<ActivityItem> doesn't accept that prop. Declared props: id, actor, title, time, body, icon, avatar, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityItem'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|info|success|warning|danger)$/]",
        "message": "<ActivityItem> tone must be one of 'neutral' | 'info' | 'success' | 'warning' | 'danger'."
