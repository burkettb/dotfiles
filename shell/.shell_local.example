#!/usr/bin/env bash
# Machine-specific shell configuration
# Copy this file to .shell_local and customize for your specific machine
# .shell_local is gitignored, so it won't sync between machines

# EXAMPLE: Work machine specific aliases
# alias work-vpn="sudo openconnect your-work-vpn.com"
# alias work-ssh="ssh user@work-server.com"

# EXAMPLE: Personal machine specific aliases  
# alias personal-backup="rsync -av ~/Documents/ /Volumes/Backup/"
# alias stream="obs --startstreaming"

# EXAMPLE: Machine-specific environment variables
# export WORK_PROJECT_DIR="~/work-projects"
# export PERSONAL_PROJECT_DIR="~/personal-projects"

# EXAMPLE: Machine-specific PATH additions
# export PATH="$PATH:/opt/work-tools/bin"
# export PATH="$PATH:~/personal-scripts"

# EXAMPLE: AWS/Git profiles
# export AWS_PROFILE="work"
# export GIT_AUTHOR_EMAIL="work@company.com"

# EXAMPLE: ColdFusion development (work machine)
# alias cfstart="sudo /opt/coldfusion2021/bin/coldfusion start"
# alias cfstop="sudo /opt/coldfusion2021/bin/coldfusion stop"
# export CF_HOME="/opt/coldfusion2021"

# EXAMPLE: Manim development (personal machine)
# alias manim-dev="cd ~/projects/manim.nvim && python -m manim"
# export MANIM_PROJECT_DIR="~/manim-projects"