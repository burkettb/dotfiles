#!/usr/bin/env bash

# List all windows across workspaces and let user select one
selected=$(aerospace list-windows --all | fzf --header="Select a window to focus")

if [ -n "$selected" ]; then
    # Extract window ID (first field)
    window_id=$(echo "$selected" | awk '{print $1}')
    
    # Focus the selected window
    aerospace focus --window-id "$window_id"
fi